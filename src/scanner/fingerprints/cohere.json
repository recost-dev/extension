{
  "schemaVersion": "1.0.0",
  "provider": "cohere",
  "displayName": "Cohere",
  "languages": ["javascript", "typescript", "python"],
  "packages": ["cohere-ai"],
  "hosts": [
    { "pattern": "api.cohere.com" },
    { "pattern": "api.cohere.ai" }
  ],
  "methods": [
    {
      "pattern": "chat",
      "httpMethod": "POST",
      "endpoint": "https://api.cohere.com/v2/chat",
      "costModel": "per_token",
      "inputPricePer1M": 0.50,
      "outputPricePer1M": 1.50,
      "cacheCapable": true,
      "description": "Chat completions — Command R ($0.50/$1.50 per 1M tokens)"
    },
    {
      "pattern": "chatStream",
      "httpMethod": "POST",
      "endpoint": "https://api.cohere.com/v2/chat",
      "costModel": "per_token",
      "inputPricePer1M": 0.50,
      "outputPricePer1M": 1.50,
      "streaming": true,
      "description": "Streaming chat — Command R"
    },
    {
      "pattern": "embed",
      "httpMethod": "POST",
      "endpoint": "https://api.cohere.com/v2/embed",
      "costModel": "per_token",
      "inputPricePer1M": 0.10,
      "batchCapable": true,
      "description": "Generate embeddings — Embed v3 ($0.10/1M tokens)"
    },
    {
      "pattern": "rerank",
      "httpMethod": "POST",
      "endpoint": "https://api.cohere.com/v2/rerank",
      "costModel": "per_request",
      "fixedFee": 0.002,
      "batchCapable": true,
      "description": "Rerank documents — Rerank 3.5 ($2.00/1K searches)"
    },
    {
      "pattern": "classify",
      "httpMethod": "POST",
      "endpoint": "https://api.cohere.com/v1/classify",
      "costModel": "per_request",
      "fixedFee": 0.002,
      "description": "Classify text inputs"
    },
    {
      "pattern": "summarize",
      "httpMethod": "POST",
      "endpoint": "https://api.cohere.com/v1/summarize",
      "costModel": "per_token",
      "inputPricePer1M": 0.50,
      "outputPricePer1M": 1.50,
      "description": "Summarize text"
    }
  ]
}
