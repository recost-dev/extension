{
  "schemaVersion": "1.0.0",
  "provider": "elevenlabs",
  "displayName": "ElevenLabs",
  "languages": ["javascript", "typescript", "python"],
  "packages": ["elevenlabs", "@elevenlabs/elevenlabs-js"],
  "hosts": [
    { "pattern": "api.elevenlabs.io" }
  ],
  "methods": [
    {
      "pattern": "textToSpeech.convert",
      "httpMethod": "POST",
      "endpoint": "https://api.elevenlabs.io/v1/text-to-speech/{voice_id}",
      "costModel": "per_request",
      "perRequestCostUsd": 0.0003,
      "cacheCapable": true,
      "description": "~$0.30/1K characters, approximated at ~1000 chars per request"
    },
    {
      "pattern": "textToSpeech.convertAsStream",
      "httpMethod": "POST",
      "endpoint": "https://api.elevenlabs.io/v1/text-to-speech/{voice_id}/stream",
      "costModel": "per_request",
      "perRequestCostUsd": 0.0003,
      "streaming": true,
      "description": "Streaming TTS — same per-character pricing as non-streaming"
    },
    {
      "pattern": "speechToText.convert",
      "httpMethod": "POST",
      "endpoint": "https://api.elevenlabs.io/v1/speech-to-text",
      "costModel": "per_request",
      "perRequestCostUsd": 0.00006,
      "cacheCapable": true,
      "description": "~$0.06/1K characters of audio transcription"
    },
    {
      "pattern": "voices.getAll",
      "httpMethod": "GET",
      "endpoint": "https://api.elevenlabs.io/v1/voices",
      "costModel": "free",
      "cacheCapable": true,
      "description": "Listing voices is free"
    },
    {
      "pattern": "voices.get",
      "httpMethod": "GET",
      "endpoint": "https://api.elevenlabs.io/v1/voices/{voice_id}",
      "costModel": "free",
      "cacheCapable": true,
      "description": "Retrieving a single voice is free"
    },
    {
      "pattern": "models.getAll",
      "httpMethod": "GET",
      "endpoint": "https://api.elevenlabs.io/v1/models",
      "costModel": "free",
      "cacheCapable": true,
      "description": "Listing models is free"
    },
    {
      "pattern": "convai.conversations.get",
      "httpMethod": "GET",
      "endpoint": "https://api.elevenlabs.io/v1/convai/conversations/{conversation_id}",
      "costModel": "per_request",
      "perRequestCostUsd": 0.001,
      "cacheCapable": true,
      "description": "Conversational AI — fetch conversation details"
    },
    {
      "pattern": "convai.conversations.getAll",
      "httpMethod": "GET",
      "endpoint": "https://api.elevenlabs.io/v1/convai/conversations",
      "costModel": "per_request",
      "perRequestCostUsd": 0.001,
      "cacheCapable": true,
      "description": "Conversational AI — list conversations"
    },
    {
      "pattern": "convai.conversations.delete",
      "httpMethod": "DELETE",
      "endpoint": "https://api.elevenlabs.io/v1/convai/conversations/{conversation_id}",
      "costModel": "free",
      "description": "Conversational AI — delete a conversation is free"
    },
    {
      "pattern": "convai.agents.get",
      "httpMethod": "GET",
      "endpoint": "https://api.elevenlabs.io/v1/convai/agents/{agent_id}",
      "costModel": "free",
      "cacheCapable": true,
      "description": "Conversational AI — fetch agent details is free"
    },
    {
      "pattern": "convai.agents.getAll",
      "httpMethod": "GET",
      "endpoint": "https://api.elevenlabs.io/v1/convai/agents",
      "costModel": "free",
      "cacheCapable": true,
      "description": "Conversational AI — list agents is free"
    }
  ]
}
