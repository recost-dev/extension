{
    "schemaVersion": "1.0.0",
    "provider": "openai",
    "displayName": "OpenAI",
    "languages": ["javascript", "typescript", "python"],
    "packages": ["openai"],
    "hosts": [
        { "pattern": "api.openai.com" }
    ],
    "methods": [
        {
            "pattern": "chat.completions.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/chat/completions",
            "costModel": "per_token",
            "inputPricePer1M": 0.15,
            "outputPricePer1M": 0.60,
            "cacheCapable": true,
            "description": "Chat completions (gpt-4o-mini representative pricing)"
        },
        {
            "pattern": "chat.completions.stream",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/chat/completions",
            "costModel": "per_token",
            "inputPricePer1M": 0.15,
            "outputPricePer1M": 0.60,
            "streaming": true,
            "description": "Streaming chat completions"
        },
        {
            "pattern": "responses.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/responses",
            "costModel": "per_token",
            "inputPricePer1M": 0.15,
            "outputPricePer1M": 0.60,
            "cacheCapable": true,
            "description": "Responses API (Realtime / stateful)"
        },
        {
            "pattern": "embeddings.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/embeddings",
            "costModel": "per_token",
            "inputPricePer1M": 0.02,
            "batchCapable": true,
            "description": "Text embeddings (text-embedding-3-small)"
        },
        {
            "pattern": "images.generate",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/images/generations",
            "costModel": "per_request",
            "fixedFee": 0.04,
            "description": "Image generation (DALL-E 3 1024×1024 standard)"
        },
        {
            "pattern": "images.edit",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/images/edits",
            "costModel": "per_request",
            "fixedFee": 0.04,
            "description": "Image editing"
        },
        {
            "pattern": "images.createVariation",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/images/variations",
            "costModel": "per_request",
            "fixedFee": 0.04,
            "description": "Image variations"
        },
        {
            "pattern": "audio.transcriptions.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/audio/transcriptions",
            "costModel": "per_request",
            "fixedFee": 0.006,
            "description": "Audio transcription — Whisper ($0.006/min)"
        },
        {
            "pattern": "audio.translations.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/audio/translations",
            "costModel": "per_request",
            "fixedFee": 0.006,
            "description": "Audio translation — Whisper ($0.006/min)"
        },
        {
            "pattern": "audio.speech.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/audio/speech",
            "costModel": "per_token",
            "inputPricePer1M": 15.0,
            "description": "Text-to-speech — TTS-1 ($15/1M chars)"
        },
        {
            "pattern": "moderations.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/moderations",
            "costModel": "free",
            "description": "Content moderation (free)"
        },
        {
            "pattern": "fine_tuning.jobs.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/fine_tuning/jobs",
            "costModel": "per_token",
            "inputPricePer1M": 8.0,
            "outputPricePer1M": 16.0,
            "description": "Fine-tuning job creation (gpt-4o-mini training $8/1M tokens)"
        },
        {
            "pattern": "fine_tuning.jobs.list",
            "httpMethod": "GET",
            "endpoint": "https://api.openai.com/v1/fine_tuning/jobs",
            "costModel": "free",
            "description": "List fine-tuning jobs"
        },
        {
            "pattern": "fine_tuning.jobs.retrieve",
            "httpMethod": "GET",
            "endpoint": "https://api.openai.com/v1/fine_tuning/jobs/{id}",
            "costModel": "free",
            "description": "Retrieve fine-tuning job"
        },
        {
            "pattern": "fine_tuning.jobs.cancel",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/fine_tuning/jobs/{id}/cancel",
            "costModel": "free",
            "description": "Cancel fine-tuning job"
        },
        {
            "pattern": "batches.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/batches",
            "costModel": "per_token",
            "inputPricePer1M": 0.075,
            "outputPricePer1M": 0.30,
            "batchCapable": true,
            "description": "Batch API — 50% discount vs. synchronous"
        },
        {
            "pattern": "batches.retrieve",
            "httpMethod": "GET",
            "endpoint": "https://api.openai.com/v1/batches/{id}",
            "costModel": "free",
            "description": "Retrieve batch status"
        },
        {
            "pattern": "batches.list",
            "httpMethod": "GET",
            "endpoint": "https://api.openai.com/v1/batches",
            "costModel": "free",
            "description": "List batches"
        },
        {
            "pattern": "batches.cancel",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/batches/{id}/cancel",
            "costModel": "free",
            "description": "Cancel batch"
        },
        {
            "pattern": "files.create",
            "httpMethod": "POST",
            "endpoint": "https://api.openai.com/v1/files",
            "costModel": "free",
            "description": "Upload a file"
        },
        {
            "pattern": "files.list",
            "httpMethod": "GET",
            "endpoint": "https://api.openai.com/v1/files",
            "costModel": "free",
            "description": "List files"
        },
        {
            "pattern": "files.retrieve",
            "httpMethod": "GET",
            "endpoint": "https://api.openai.com/v1/files/{id}",
            "costModel": "free",
            "description": "Retrieve file metadata"
        },
        {
            "pattern": "files.delete",
            "httpMethod": "DELETE",
            "endpoint": "https://api.openai.com/v1/files/{id}",
            "costModel": "free",
            "description": "Delete a file"
        },
        {
            "pattern": "models.list",
            "httpMethod": "GET",
            "endpoint": "https://api.openai.com/v1/models",
            "costModel": "free",
            "description": "List available models"
        },
        {
            "pattern": "models.retrieve",
            "httpMethod": "GET",
            "endpoint": "https://api.openai.com/v1/models/{id}",
            "costModel": "free",
            "description": "Retrieve a model"
        }
    ]
}
